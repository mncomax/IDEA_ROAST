# === Telegram ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# === LLM APIs (mindestens EINES muss gesetzt sein) ===
# Claude: wird fuer Devils Advocate, Analyse, Out-of-Box genutzt (Qualitaet)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GPT: wird fuer Brainstorm, Zusammenfassungen, Formatting genutzt (guenstig)
OPENAI_API_KEY=your_openai_api_key_here

# === Reddit API (https://www.reddit.com/prefs/apps) ===
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=IdeaRoast/1.0

# === GitHub (optional, erhoeht Rate Limits) ===
GITHUB_TOKEN=your_github_token_here

# === SearXNG (self-hosted) ===
SEARXNG_BASE_URL=http://searxng:8080

# === faster-whisper (self-hosted) ===
WHISPER_BASE_URL=http://whisper:8000

# === Database ===
DATABASE_PATH=/app/data/idearoast.db

# === Logging ===
LOG_LEVEL=INFO

# === Allowed Telegram User IDs (comma-separated, for personal use security) ===
ALLOWED_USER_IDS=your_telegram_user_id_here
